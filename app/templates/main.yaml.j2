mixed-port: 7890
allow-lan: false
mode: rule
log-level: info
ipv6: false
external-controller: 127.0.0.1:9090

profile:
  store-selected: true
  store-fake-ip: true

dns:
  enable: true
  ipv6: false
  enhanced-mode: fake-ip
  nameserver:
    - 1.1.1.1
    - 8.8.8.8

proxy-providers:
  wardenwg-nodes-{{ device.subscription_token[:8] }}:
    type: http
    url: {{ nodes_url }}
    path: ./providers/wardenwg-nodes-{{ device.subscription_token[:8] }}.yaml
    interval: 3600
    health-check:
      enable: true
      url: https://cp.cloudflare.com/generate_204
      interval: 300

proxy-groups:
  - name: PROXY
    type: select
    use:
      - wardenwg-nodes-{{ device.subscription_token[:8] }}
    proxies:
      - DIRECT
  - name: AUTO
    type: url-test
    use:
      - wardenwg-nodes-{{ device.subscription_token[:8] }}
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 100
  - name: FINAL
    type: select
    proxies:
      - PROXY
      - AUTO
      - DIRECT

rules:
  - GEOIP,CN,DIRECT
  - MATCH,PROXY

